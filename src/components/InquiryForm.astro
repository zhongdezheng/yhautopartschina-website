---
import { siteConfig } from '../data/products';
---

<section id="inquiry" class="py-20 sm:py-24 px-4 sm:px-6 bg-steel-950/50 border-y border-steel-800/20">
  <div class="mx-auto max-w-2xl">
    <div class="flex flex-col items-center mb-10 sm:mb-12 text-center">
      <span data-i18n="inquiry.section" class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase mb-2">联系我们</span>
      <h2 data-i18n="inquiry.heading" class="text-2xl sm:text-3xl md:text-4xl font-display font-black text-steel-50">发送询盘</h2>
      <div class="flex flex-col items-center gap-0.5 mt-3">
        <span class="block w-10 h-px bg-crest-gold/50"></span>
        <span class="block w-6 h-px bg-crest-gold/20"></span>
      </div>
    </div>

    <form action="/thank-you" method="POST" class="space-y-5 sm:space-y-6">
      <div>
        <label data-i18n="inquiry.name" for="name" class="block text-[10px] sm:text-xs tracking-wider uppercase text-steel-400 mb-2">姓名 / 公司名 *</label>
        <input type="text" id="name" name="name" required
          class="w-full bg-steel-900 border border-steel-700 text-steel-100 px-3 sm:px-4 py-2.5 sm:py-3 text-sm
                 focus:border-crest-gold/50 focus:outline-none transition-colors placeholder-steel-600"
          data-i18n-ph="inquiry.namePlaceholder" placeholder="您的姓名或公司名称" />
      </div>

      <div>
        <label data-i18n="inquiry.email" for="email" class="block text-[10px] sm:text-xs tracking-wider uppercase text-steel-400 mb-2">邮箱 *</label>
        <input type="email" id="email" name="email" required
          class="w-full bg-steel-900 border border-steel-700 text-steel-100 px-3 sm:px-4 py-2.5 sm:py-3 text-sm
                 focus:border-crest-gold/50 focus:outline-none transition-colors placeholder-steel-600"
          data-i18n-ph="inquiry.emailPlaceholder" placeholder="your@email.com" />
      </div>

      <div>
        <label data-i18n="inquiry.vehicle" for="vehicle" class="block text-[10px] sm:text-xs tracking-wider uppercase text-steel-400 mb-2">目标车型 / 发动机型号</label>
        <input type="text" id="vehicle" name="vehicle"
          class="w-full bg-steel-900 border border-steel-700 text-steel-100 px-3 sm:px-4 py-2.5 sm:py-3 text-sm
                 focus:border-crest-gold/50 focus:outline-none transition-colors placeholder-steel-600"
          data-i18n-ph="inquiry.vehiclePlaceholder" placeholder="例如：奥迪 Q7 3.0T, 宝马 525i N52" />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label data-i18n="inquiry.quantity" for="quantity" class="block text-[10px] sm:text-xs tracking-wider uppercase text-steel-400 mb-2">采购数量</label>
          <input type="text" id="quantity" name="quantity"
            class="w-full bg-steel-900 border border-steel-700 text-steel-100 px-3 sm:px-4 py-2.5 sm:py-3 text-sm
                   focus:border-crest-gold/50 focus:outline-none transition-colors placeholder-steel-600"
            data-i18n-ph="inquiry.quantityPlaceholder" placeholder="例如：100 套" />
        </div>
        <div>
          <label data-i18n="inquiry.market" for="market-select" class="block text-[10px] sm:text-xs tracking-wider uppercase text-steel-400 mb-2">目标市场</label>
          <div id="custom-dropdown" class="relative">
            <button type="button" id="dropdown-btn"
              class="w-full bg-steel-900 border border-steel-700 text-steel-100 px-3 sm:px-4 py-2.5 sm:py-3 text-sm
                     focus:border-crest-gold/50 focus:outline-none transition-colors text-left flex items-center justify-between group">
              <span id="dropdown-label" class="text-steel-400">选择地区</span>
              <svg class="w-3.5 h-3.5 text-steel-500 group-hover:text-crest-gold/60 transition-colors ml-2 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </button>
            <div id="dropdown-panel"
              class="absolute left-0 right-0 top-full mt-1 z-20 bg-steel-900 border border-steel-700 overflow-hidden
                     max-h-0 opacity-0 pointer-events-none transition-all duration-200 origin-top"
              style="box-shadow: 0 12px 32px rgba(0,0,0,0.6), 0 0 0 1px rgba(200,169,110,0.1);">
              <!-- Options loaded by JS -->
            </div>
            <input type="hidden" id="market-select" name="market" value="" />
          </div>
        </div>
      </div>

      <button data-i18n="inquiry.submit" type="submit"
        class="w-full py-3 sm:py-3.5 bg-crest-gold text-crest-dark font-semibold text-sm tracking-wider uppercase
               hover:bg-crest-gold/90 active:scale-[0.99] transition-all">
        发送询盘 →
      </button>

    </form>
  </div>
</section>

<script is:inline>
  (function () {
    const options = [
      { value: '', label: '选择地区', placeholder: true },
      { value: 'southeast-asia', label: 'Southeast Asia' },
      { value: 'middle-east', label: 'Middle East' },
      { value: 'africa', label: 'Africa' },
    ];

    const translations = {
      zh: { placeholder: '选择地区', label: '目标市场' },
      en: { placeholder: 'Select region', label: 'Target Market' },
      ru: { placeholder: 'Выберите регион', label: 'Целевой рынок' },
      ar: { placeholder: 'اختر المنطقة', label: 'السوق المستهدف' },
      vi: { placeholder: 'Chọn khu vực', label: 'Thị trường mục tiêu' },
      th: { placeholder: 'เลือกภูมิภาค', label: 'ตลาดเป้าหมาย' },
    };

    const p = new URLSearchParams(window.location.search);
    const lang = ['zh','en','ru','ar','vi','th'].includes(p.get('lang')) ? p.get('lang') : 'zh';
    const t = translations[lang] || translations.zh;

    const btn = document.getElementById('dropdown-btn');
    const panel = document.getElementById('dropdown-panel');
    const label = document.getElementById('dropdown-label');
    const hidden = document.getElementById('market-select');

    let isOpen = false, selectedValue = '';

    // Build options
    panel.innerHTML = options.map((o, i) => {
      const isPH = o.placeholder;
      const text = isPH ? t.placeholder : o.label;
      return `<div class="dropdown-option px-3 sm:px-4 py-2 sm:py-2.5 text-sm cursor-pointer transition-colors
        ${isPH ? 'text-steel-500 italic' : 'text-steel-300 hover:bg-steel-800 hover:text-crest-gold'}
        border-b border-steel-800/30 last:border-b-0"
        data-value="${o.value}">${text}</div>`;
    });

    function open() {
      isOpen = true;
      panel.style.maxHeight = '300px';
      panel.style.opacity = '1';
      panel.style.pointerEvents = 'auto';
      btn.querySelector('svg').style.transform = 'rotate(180deg)';
      btn.style.borderColor = 'rgba(200,169,110,0.5)';
    }

    function close() {
      isOpen = false;
      panel.style.maxHeight = '0';
      panel.style.opacity = '0';
      panel.style.pointerEvents = 'none';
      btn.querySelector('svg').style.transform = 'rotate(0deg)';
      btn.style.borderColor = '';
    }

    btn.addEventListener('click', e => { e.stopPropagation(); isOpen ? close() : open(); });

    panel.addEventListener('click', e => {
      const opt = e.target.closest('.dropdown-option');
      if (!opt) return;
      selectedValue = opt.dataset.value;
      hidden.value = selectedValue;
      label.textContent = opt.textContent;
      label.classList.toggle('text-steel-400', !selectedValue);
      label.classList.toggle('text-crest-gold', !!selectedValue);
      close();
    });

    document.addEventListener('click', () => { if (isOpen) close(); });
  })();
</script>

<style is:global>
  .dropdown-option:hover {
    background: linear-gradient(90deg, rgba(200,169,110,0.08) 0%, transparent 100%);
  }
  .dropdown-option:active {
    background: rgba(200,169,110,0.15);
  }
</style>
