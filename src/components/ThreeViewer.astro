---
// ThreeViewer.astro – Animated engine piston & crankshaft assembly
---

<div
  id="canvas-container"
  class="relative w-full aspect-[4/3] sm:aspect-[16/9] md:aspect-[2/1] bg-gradient-to-b from-steel-950 to-steel-900 border border-steel-800/30 rounded-sm overflow-hidden cursor-grab active:cursor-grabbing"
>
  <div id="three-loading" class="absolute inset-0 flex flex-col items-center justify-center gap-3 z-10 bg-steel-950/80">
    <div class="relative w-16 h-16">
      <div class="absolute inset-0 border-2 border-crest-gold/30 rounded-full animate-ping"></div>
      <div class="absolute inset-0 border-2 border-crest-gold/60 rounded-full"></div>
    </div>
    <p class="text-steel-400 text-xs tracking-[0.2em] uppercase">Loading 3D</p>
  </div>

  <div id="three-controls" class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 sm:gap-3 z-10">
    <button id="btn-play" class="text-[10px] sm:text-xs tracking-wider uppercase bg-crest-dark/90 text-crest-gold border border-crest-gold/50 px-3 py-1.5 rounded-full hover:bg-crest-dark transition-all duration-300">⏯ Run</button>
    <button id="btn-speed" class="text-[10px] sm:text-xs tracking-wider uppercase bg-crest-dark/90 text-steel-300 border border-steel-700 px-3 py-1.5 rounded-full hover:border-crest-gold/50 hover:text-crest-gold transition-all duration-300">⏩ 2×</button>
    <button id="btn-reset" class="text-[10px] sm:text-xs tracking-wider uppercase bg-crest-dark/90 text-steel-300 border border-steel-700 px-3 py-1.5 rounded-full hover:border-crest-gold/50 hover:text-crest-gold transition-all duration-300">↺ Reset</button>
  </div>
</div>

<script type="module" is:inline>
  import * as THREE from 'three';

  const container = document.getElementById('canvas-container');
  const loading = document.getElementById('three-loading');
  const btnPlay = document.getElementById('btn-play');
  const btnSpeed = document.getElementById('btn-speed');
  const btnReset = document.getElementById('btn-reset');

  // ======= SCENE =======
  const scene = new THREE.Scene();
  scene.background = new THREE.Color(0x0d0d14);
  scene.fog = new THREE.Fog(0x0d0d14, 5, 16);

  const camera = new THREE.PerspectiveCamera(40, container.clientWidth / container.clientHeight, 0.1, 50);
  camera.position.set(5, 3, 9);
  camera.lookAt(0, 0, 0);

  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(container.clientWidth, container.clientHeight);
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.2;
  renderer.outputColorSpace = THREE.SRGBColorSpace;
  container.appendChild(renderer.domElement);
  renderer.domElement.style.cssText = 'display:block;width:100%;height:100%';

  // ======= LIGHTING =======
  scene.add(new THREE.AmbientLight(0x334466, 2));
  const key = new THREE.DirectionalLight(0xffeedd, 5);
  key.position.set(6, 8, 3);
  key.castShadow = true;
  key.shadow.mapSize.set(2048, 2048);
  key.shadow.camera.near = 0.5; key.shadow.camera.far = 30;
  key.shadow.camera.left = -6; key.shadow.camera.right = 6;
  key.shadow.camera.top = 6; key.shadow.camera.bottom = -6;
  key.shadow.bias = -0.0002;
  scene.add(key);

  const fill = new THREE.DirectionalLight(0x8899cc, 2);
  fill.position.set(-3, 1, -2);
  scene.add(fill);
  const rim = new THREE.DirectionalLight(0xC8A96E, 2.5);
  rim.position.set(-1, 0.5, -6);
  scene.add(rim);

  // ======= FLOOR =======
  const floor = new THREE.Mesh(
    new THREE.PlaneGeometry(16, 16),
    new THREE.MeshStandardMaterial({ color: 0x1a1a24, roughness: 0.5, metalness: 0.4 })
  );
  floor.rotation.x = -Math.PI / 2; floor.position.y = -3.2;
  floor.receiveShadow = true;
  scene.add(floor);

  const grid = new THREE.PolarGridHelper(6, 32, 24, 64, 0x333344, 0x222233);
  grid.position.y = -3.18;
  scene.add(grid);

  // ======= MATERIALS =======
  const m = {
    alu: new THREE.MeshStandardMaterial({ color: 0xd0d0d8, roughness: 0.18, metalness: 0.9 }),
    crown: new THREE.MeshStandardMaterial({ color: 0x9999aa, roughness: 0.3, metalness: 0.7 }),
    skirt: new THREE.MeshStandardMaterial({ color: 0xbbbbbb, roughness: 0.15, metalness: 0.85 }),
    ring: new THREE.MeshStandardMaterial({ color: 0x555566, roughness: 0.1, metalness: 0.98 }),
    goldRing: new THREE.MeshStandardMaterial({ color: 0xc8a96e, roughness: 0.15, metalness: 0.95 }),
    pin: new THREE.MeshStandardMaterial({ color: 0x666677, roughness: 0.08, metalness: 0.97 }),
    rod: new THREE.MeshStandardMaterial({ color: 0x9999aa, roughness: 0.2, metalness: 0.88 }),
    crank: new THREE.MeshStandardMaterial({ color: 0x888899, roughness: 0.2, metalness: 0.9 }),
    cw: new THREE.MeshStandardMaterial({ color: 0x777788, roughness: 0.25, metalness: 0.85 }),
    gold: new THREE.MeshStandardMaterial({ color: 0xc8a96e, roughness: 0.2, metalness: 0.9 }),
  };

  function makePistonAssembly() {
    const g = new THREE.Group();

    // Crown
    const crown = new THREE.Mesh(new THREE.CylinderGeometry(0.38, 0.38, 0.06, 48), m.crown);
    crown.position.y = 0; crown.castShadow = true;
    g.add(crown);

    const crownTop = new THREE.Mesh(new THREE.CylinderGeometry(0.34, 0.38, 0.025, 48), m.crown);
    crownTop.position.y = 0.042; crownTop.castShadow = true;
    g.add(crownTop);

    // Valve reliefs
    for (let i = 0; i < 4; i++) {
      const a = (i / 4) * Math.PI * 2 + Math.PI / 4;
      const r = new THREE.Mesh(
        new THREE.SphereGeometry(0.08, 12, 6, 0, Math.PI * 2, 0, Math.PI / 3),
        new THREE.MeshStandardMaterial({ color: 0x777788, roughness: 0.4, metalness: 0.6 })
      );
      r.position.set(Math.cos(a) * 0.18, 0.06, Math.sin(a) * 0.18);
      r.scale.set(1, 0.3, 1);
      g.add(r);
    }

    // Ring belt
    const belt = new THREE.Mesh(new THREE.CylinderGeometry(0.37, 0.37, 0.24, 48), m.alu);
    belt.position.y = -0.13; belt.castShadow = true;
    g.add(belt);

    // Ring grooves
    for (let i = 0; i < 3; i++) {
      const groove = new THREE.Mesh(
        new THREE.TorusGeometry(0.37 - 0.032, 0.032, 10, 48),
        new THREE.MeshStandardMaterial({ color: 0x222222, roughness: 0.6, metalness: 0.4 })
      );
      groove.rotation.x = Math.PI / 2; groove.position.y = -0.22 - i * 0.07;
      g.add(groove);
    }

    // Rings
    for (let i = 0; i < 3; i++) {
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(0.34, 0.02, 12, 48),
        i === 0 ? m.goldRing : m.ring
      );
      ring.rotation.x = Math.PI / 2; ring.position.y = -0.22 - i * 0.07;
      ring.castShadow = true;
      g.add(ring);
    }

    // Skirt
    const skirt = new THREE.Mesh(
      new THREE.CylinderGeometry(0.375, 0.33, 0.26, 48, 1, true), m.skirt
    );
    skirt.position.y = -0.36; skirt.castShadow = true;
    g.add(skirt);

    const bottom = new THREE.Mesh(new THREE.CylinderGeometry(0.26, 0.33, 0.03, 48), m.alu);
    bottom.position.y = -0.5; bottom.castShadow = true;
    g.add(bottom);

    // Wrist pin
    const pinG = new THREE.Group();
    const pin = new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.06, 0.56, 24), m.pin);
    pin.rotation.z = Math.PI / 2;
    pinG.add(pin);
    pinG.position.y = -0.42;
    g.add(pinG);

    g.userData.pinY = pinG.position.y;

    // Connecting rod
    const rodG = new THREE.Group();

    // Small end
    const smallEnd = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 0.12, 24), m.rod);
    smallEnd.rotation.z = Math.PI / 2;
    rodG.add(smallEnd);

    // Beam
    const beamShape = new THREE.Shape();
    beamShape.moveTo(-0.06, -0.35);
    beamShape.lineTo(-0.04, 0);
    beamShape.lineTo(-0.025, 0.06);
    beamShape.lineTo(0.025, 0.06);
    beamShape.lineTo(0.04, 0);
    beamShape.lineTo(0.06, -0.35);
    beamShape.closePath();
    const beam = new THREE.Mesh(
      new THREE.ExtrudeGeometry(beamShape, { steps: 1, depth: 0.06, bevelEnabled: true, bevelThickness: 0.015, bevelSize: 0.01, bevelSegments: 3 }),
      m.rod
    );
    beam.position.set(-0.03, 0, -0.03);
    beam.castShadow = true;
    rodG.add(beam);

    // Big end
    const bigOuter = new THREE.Mesh(new THREE.CylinderGeometry(0.14, 0.14, 0.12, 24), m.rod);
    bigOuter.rotation.z = Math.PI / 2; bigOuter.position.y = -0.35;
    bigOuter.castShadow = true;
    rodG.add(bigOuter);

    const bigInner = new THREE.Mesh(
      new THREE.CylinderGeometry(0.08, 0.08, 0.13, 24),
      new THREE.MeshStandardMaterial({ color: 0x333344, roughness: 0.5, metalness: 0.4 })
    );
    bigInner.rotation.z = Math.PI / 2; bigInner.position.y = -0.35;
    rodG.add(bigInner);

    rodG.position.y = -0.42;
    g.add(rodG);
    g.userData.rodTopY = rodG.position.y;

    return g;
  }

  function makeCrank(crankRadius) {
    const g = new THREE.Group();
    const segs = 32;

    // Main shaft
    const shaft = new THREE.Mesh(new THREE.CylinderGeometry(0.08, 0.08, 2.8, segs), m.crank);
    shaft.rotation.z = Math.PI / 2;
    shaft.castShadow = true;
    g.add(shaft);

    // Crank throws for 3 pistons
    for (let i = 0; i < 3; i++) {
      const angle = (i / 3) * Math.PI * 2;
      const cx = Math.cos(angle) * crankRadius;
      const cy = Math.sin(angle) * crankRadius;

      // Crank arm (disc)
      const arm = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 0.08, segs), m.crank);
      arm.rotation.z = Math.PI / 2;
      arm.position.set(0, cy, cx);
      arm.castShadow = true;
      g.add(arm);

      // Crank pin (where rod connects)
      const pin = new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.06, 0.18, segs), m.pin);
      pin.rotation.z = Math.PI / 2;
      pin.position.set(0, cy, cx);
      g.add(pin);

      // Web / counterweight
      const webGeo = new THREE.CylinderGeometry(0.14, 0.08, 0.06, segs);
      const web = new THREE.Mesh(webGeo, m.cw);
      web.rotation.z = Math.PI / 2;
      // Opposite side to throw
      const wAngle = angle + Math.PI;
      web.position.set(0, Math.sin(wAngle) * crankRadius * 0.6, Math.cos(wAngle) * crankRadius * 0.6);
      web.castShadow = true;
      g.add(web);
    }

    return g;
  }

  // ======= BUILD ENGINE =======
  const crankRadius = 0.55;
  const engineGroup = new THREE.Group();
  scene.add(engineGroup);

  // Crankshaft
  const crankGroup = makeCrank(crankRadius);
  crankGroup.position.y = -2.0;
  engineGroup.add(crankGroup);

  // 3 pistons at 120° offsets
  const pistons = [];
  const rodConnections = [];
  for (let i = 0; i < 3; i++) {
    const piston = makePistonAssembly();
    piston.position.z = (i - 1) * 0.9;
    engineGroup.add(piston);
    pistons.push(piston);
  }

  // Cylinder walls (transparent)
  for (let i = 0; i < 3; i++) {
    const cylGeo = new THREE.CylinderGeometry(0.39, 0.39, 0.4, 48, 1, true);
    const cyl = new THREE.Mesh(cylGeo, new THREE.MeshStandardMaterial({
      color: 0x8899cc, roughness: 0.3, metalness: 0.1,
      transparent: true, opacity: 0.15, depthWrite: false
    }));
    cyl.position.set(0, 0.85, (i - 1) * 0.9);
    engineGroup.add(cyl);
  }

  // Floating rings
  const floatRings = [];
  for (let i = 0; i < 6; i++) {
    const ring = new THREE.Mesh(
      new THREE.TorusGeometry(0.34, 0.015, 12, 48),
      i < 2 ? m.goldRing : m.ring
    );
    ring.castShadow = true;
    ring.userData = {
      orbitR: 2.5 + Math.random() * 2,
      orbitSpeed: 0.2 + Math.random() * 0.4,
      orbitOff: Math.random() * Math.PI * 2,
      vertAmp: 1.5 + Math.random() * 1,
      vertSpeed: 0.2 + Math.random() * 0.3,
      vertOff: Math.random() * Math.PI * 2,
      tiltX: (Math.random() - 0.5) * 1,
      tiltZ: (Math.random() - 0.5) * 1,
    };
    scene.add(ring);
    floatRings.push(ring);
  }

  // Gold particles
  const particlesGeo = new THREE.BufferGeometry();
  const pCount = 150;
  const pPos = new Float32Array(pCount * 3);
  for (let i = 0; i < pCount; i++) {
    pPos[i * 3] = (Math.random() - 0.5) * 8;
    pPos[i * 3 + 1] = Math.random() * 5 - 1;
    pPos[i * 3 + 2] = (Math.random() - 0.5) * 8;
  }
  particlesGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
  const particles = new THREE.Points(particlesGeo, new THREE.PointsMaterial({
    color: 0xC8A96E, size: 0.012, transparent: true, opacity: 0.5,
    blending: THREE.AdditiveBlending, depthWrite: false,
  }));
  scene.add(particles);

  // ======= STATE =======
  let isPlaying = true;
  let speed = 1;
  let crankAngle = 0;

  // Drag rotation
  let isDragging = false, prevX = 0, prevY = 0;
  let sceneRotY = 0.5, targetRotY = 0.5;
  let sceneRotX = 0.3, targetRotX = 0.3;
  let zoom = 9, targetZoom = 9;

  container.addEventListener('mousedown', e => { isDragging = true; prevX = e.clientX; prevY = e.clientY; });
  container.addEventListener('touchstart', e => {
    if (e.touches.length === 1) { isDragging = true; prevX = e.touches[0].clientX; prevY = e.touches[0].clientY; }
  });
  window.addEventListener('mousemove', e => {
    if (!isDragging) return;
    targetRotY += (e.clientX - prevX) * 0.004;
    targetRotX -= (e.clientY - prevY) * 0.004;
    targetRotX = Math.max(-1.2, Math.min(1.2, targetRotX));
    prevX = e.clientX; prevY = e.clientY;
  });
  window.addEventListener('touchmove', e => {
    if (!isDragging || e.touches.length !== 1) return;
    targetRotY += (e.touches[0].clientX - prevX) * 0.004;
    targetRotX -= (e.touches[0].clientY - prevY) * 0.004;
    targetRotX = Math.max(-1.2, Math.min(1.2, targetRotX));
    prevX = e.touches[0].clientX; prevY = e.touches[0].clientY;
  });
  window.addEventListener('mouseup', () => isDragging = false);
  window.addEventListener('touchend', () => isDragging = false);
  container.addEventListener('wheel', e => {
    e.preventDefault();
    targetZoom += e.deltaY * 0.005;
    targetZoom = Math.max(4, Math.min(15, targetZoom));
  }, { passive: false });

  // Buttons
  btnPlay.addEventListener('click', () => {
    isPlaying = !isPlaying;
    btnPlay.innerHTML = isPlaying ? '⏯ Run' : '▶ Play';
    btnPlay.classList.toggle('text-crest-gold', isPlaying);
    btnPlay.classList.toggle('border-crest-gold/50', isPlaying);
  });

  btnSpeed.addEventListener('click', () => {
    speed = speed === 1 ? 2 : speed === 2 ? 4 : 1;
    btnSpeed.textContent = '⏩ ' + speed + '×';
  });

  btnReset.addEventListener('click', () => {
    targetRotX = 0.3; targetRotY = 0.5;
    targetZoom = 9; speed = 1;
    btnSpeed.textContent = '⏩ 1×';
    if (!isPlaying) {
      isPlaying = true;
      btnPlay.innerHTML = '⏯ Run';
      btnPlay.classList.add('text-crest-gold', 'border-crest-gold/50');
    }
  });

  // ======= ANIMATION =======
  const clock = new THREE.Clock();

  function animate() {
    requestAnimationFrame(animate);
    const dt = Math.min(clock.getDelta(), 0.1);
    const t = performance.now() * 0.001;

    // Smooth camera
    sceneRotX += (targetRotX - sceneRotX) * 0.08;
    sceneRotY += (targetRotY - sceneRotY) * 0.08;
    zoom += (targetZoom - zoom) * 0.08;

    engineGroup.rotation.y = sceneRotY;
    engineGroup.rotation.x = sceneRotX;

    const d = zoom;
    camera.position.x = Math.sin(sceneRotY) * d;
    camera.position.z = Math.cos(sceneRotY) * d;
    camera.position.y = 1 + sceneRotX * 3;
    camera.lookAt(0, -0.3, 0);

    // Engine rotation
    if (isPlaying) {
      crankAngle += dt * speed * 2.5;
    }

    crankGroup.rotation.x = crankAngle;

    // Update piston positions based on crank angle
    for (let i = 0; i < 3; i++) {
      const angle = crankAngle + (i / 3) * Math.PI * 2;
      const py = Math.cos(angle) * crankRadius;
      // Piston vertical: top position is ~1.15, stroke is crankRadius*2
      const pistonY = 0.5 + py;
      pistons[i].position.y = pistonY;

      // Rod big end follows crank pin
      const rodG = pistons[i].children.find(c => c.type === 'Group' && c.children.length >= 5);
      if (rodG) {
        const rodAngle = Math.asin(Math.sin(angle) * crankRadius / 1.2);
        rodG.rotation.z = rodAngle;
      }
    }

    // Floating rings
    floatRings.forEach(r => {
      const d = r.userData;
      const a = t * d.orbitSpeed + d.orbitOff;
      r.position.x = Math.cos(a) * d.orbitR;
      r.position.z = Math.sin(a) * d.orbitR;
      r.position.y = Math.sin(t * d.vertSpeed + d.vertOff) * d.vertAmp;
      r.rotation.x = Math.sin(t * 0.7) * d.tiltX + Math.PI / 2;
      r.rotation.z = Math.cos(t * 0.5) * d.tiltZ;
    });

    particles.rotation.y += dt * 0.05;

    renderer.render(scene, camera);
  }

  setTimeout(() => {
    if (loading) { loading.style.opacity = '0'; setTimeout(() => { if (loading) loading.style.display = 'none'; }, 400); }
  }, 300);

  animate();

  window.addEventListener('resize', () => {
    camera.aspect = container.clientWidth / container.clientHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(container.clientWidth, container.clientHeight);
  });
</script>
