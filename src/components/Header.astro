---
import { products } from '../data/products';
const cp = Astro.url.pathname;
const nc = (p) => {
  const b = 'px-3 sm:px-4 py-1.5 sm:py-2 text-[11px] sm:text-sm font-medium tracking-wide uppercase border transition-colors';
  const active = (p === '/' && cp === '/') || (p !== '/' && cp.startsWith(p));
  if (active) return `${b} text-crest-gold border-crest-gold/50`;
  return `${b} text-steel-400 border-steel-700 hover:border-crest-gold/30 hover:text-crest-gold`;
};
---


<header class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-crest-dark/90 border-b border-steel-800/50">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 py-2 sm:py-3" dir="ltr">
    <div class="flex items-center justify-between gap-3">
      <!-- Logo -->
      <a href="/" class="group flex items-center gap-3 flex-shrink-0 lang-link">
        <div class="flex flex-col items-center leading-none">
          <span class="text-crest-gold text-xs tracking-[0.3em] font-medium uppercase">YH</span>
          <span class="text-steel-200 text-[10px] tracking-[0.5em] uppercase">Auto Parts</span>
        </div>
        <span class="block w-px h-6 sm:h-8 bg-crest-gold/30" aria-hidden="true"></span>
        <span data-i18n="nav.since" class="text-steel-400 text-[10px] sm:text-xs tracking-[0.2em] hidden sm:block">始于 2002</span>
      </a>

      <!-- Right side: nav buttons + language switcher -->
      <div class="flex items-center gap-1.5 sm:gap-2">
        <a href="/" class={"lang-link " + nc('/')}>首页</a>
        <a href="/pistons" class={"lang-link " + nc('/pistons')}>活塞</a>
        <a href="/piston-rings" class={"lang-link " + nc('/piston-rings')}>活塞环</a>

        <div class="w-px h-6 bg-steel-700/50 mx-1 hidden sm:block"></div>

        <div class="relative" id="lang-dropdown">
          <button id="lang-btn" class="flex items-center gap-1 px-2 sm:px-3 py-1.5 sm:py-2 text-steel-400 border border-steel-700 hover:border-crest-gold/40 hover:text-steel-200 transition-colors text-[11px] sm:text-sm">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span id="lang-label">中文</span>
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div id="lang-panel" class="absolute right-0 top-full mt-1 z-30 bg-steel-900 border border-steel-700 overflow-hidden min-w-[120px] max-h-0 opacity-0 pointer-events-none transition-all duration-200" style="box-shadow: 0 8px 24px rgba(0,0,0,0.6);">
            <a href="?lang=zh" data-lang="zh" class="block px-4 py-2 text-xs text-steel-300 hover:bg-steel-800 hover:text-crest-gold transition-colors border-b border-steel-800/30">中文</a>
            <a href="?lang=en" data-lang="en" class="block px-4 py-2 text-xs text-steel-300 hover:bg-steel-800 hover:text-crest-gold transition-colors border-b border-steel-800/30">English</a>
            <a href="?lang=ru" data-lang="ru" class="block px-4 py-2 text-xs text-steel-300 hover:bg-steel-800 hover:text-crest-gold transition-colors border-b border-steel-800/30">Русский</a>
            <a href="?lang=ar" data-lang="ar" class="block px-4 py-2 text-xs text-steel-300 hover:bg-steel-800 hover:text-crest-gold transition-colors border-b border-steel-800/30">العربية</a>
            <a href="?lang=vi" data-lang="vi" class="block px-4 py-2 text-xs text-steel-300 hover:bg-steel-800 hover:text-crest-gold transition-colors border-b border-steel-800/30">Tiếng Việt</a>
            <a href="?lang=th" data-lang="th" class="block px-4 py-2 text-xs text-steel-300 hover:bg-steel-800 hover:text-crest-gold transition-colors">ไทย</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Search bar -->
    <div class="mt-2 relative" id="header-search">
      <div class="flex items-center gap-2 mx-auto max-w-md">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-steel-500 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="search-input" autocomplete="off" placeholder="Search by OEM / model / part number..." class="w-full bg-steel-900/80 border border-steel-700/60 text-steel-200 text-xs sm:text-sm pl-9 pr-3 py-1.5 sm:py-2 focus:border-crest-gold/40 focus:outline-none focus:bg-steel-900 transition-all placeholder-steel-600 rounded-none"/>
          <button type="button" id="search-clear" class="absolute right-2 top-1/2 -translate-y-1/2 w-4 h-4 text-steel-500 hover:text-steel-300 hidden items-center justify-center">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>
      <div id="search-results" class="absolute left-4 right-4 sm:left-auto sm:right-auto sm:w-full sm:max-w-md top-full mt-1 z-30 bg-steel-900 border border-steel-700 overflow-hidden max-h-0 opacity-0 pointer-events-none transition-all duration-200" style="box-shadow: 0 16px 40px rgba(0,0,0,0.7), 0 0 0 1px rgba(200,169,110,0.1);"></div>
    </div>
  </nav>
</header>

