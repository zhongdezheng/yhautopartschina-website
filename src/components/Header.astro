---
import { products } from '../data/products';
---

<header class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-crest-dark/90 border-b border-steel-800/50">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 py-2 sm:py-3" dir="ltr">
    <!-- Top row: logo + languages -->
    <div class="flex items-center justify-between">
      <a href="/" class="group flex items-center gap-3 flex-shrink-0">
        <div class="flex flex-col items-center leading-none">
          <span class="text-crest-gold text-xs tracking-[0.3em] font-medium uppercase">YH</span>
          <span class="text-steel-200 text-[10px] tracking-[0.5em] uppercase">Auto Parts</span>
        </div>
        <span class="block w-px h-6 sm:h-8 bg-crest-gold/30" aria-hidden="true"></span>
        <span data-i18n="nav.since" class="text-steel-400 text-[10px] sm:text-xs tracking-[0.2em] hidden sm:block">始于 2002</span>
      </a>

      <div class="flex items-center gap-0.5 sm:gap-1">
        <a href="?lang=zh" class="px-1.5 sm:px-2 py-0.5 sm:py-1 text-[10px] sm:text-xs font-medium tracking-wide text-steel-400 hover:text-steel-200 transition-colors">中文</a>
        <a href="?lang=en" class="px-1.5 sm:px-2 py-0.5 sm:py-1 text-[10px] sm:text-xs font-medium tracking-wide text-steel-400 hover:text-steel-200 transition-colors">EN</a>
        <a href="?lang=ru" class="px-1.5 sm:px-2 py-0.5 sm:py-1 text-[10px] sm:text-xs font-medium tracking-wide text-steel-400 hover:text-steel-200 transition-colors">Рус</a>
        <a href="?lang=ar" class="px-1.5 sm:px-2 py-0.5 sm:py-1 text-[10px] sm:text-xs font-medium tracking-wide text-steel-400 hover:text-steel-200 transition-colors">العربية</a>
        <a href="?lang=vi" class="px-1.5 sm:px-2 py-0.5 sm:py-1 text-[10px] sm:text-xs font-medium tracking-wide text-steel-400 hover:text-steel-200 transition-colors">Tiếng Việt</a>
        <a href="?lang=th" class="px-1.5 sm:px-2 py-0.5 sm:py-1 text-[10px] sm:text-xs font-medium tracking-wide text-steel-400 hover:text-steel-200 transition-colors">ไทย</a>
      </div>
    </div>

    <!-- Bottom row: search -->
    <div class="mt-2 relative" id="header-search">
      <div class="flex items-center gap-2 mx-auto max-w-md">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-steel-500 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input
            type="text"
            id="search-input"
            autocomplete="off"
            placeholder="Search by OEM / model / part number..."
            class="w-full bg-steel-900/80 border border-steel-700/60 text-steel-200 text-xs sm:text-sm pl-9 pr-3 py-1.5 sm:py-2
                   focus:border-crest-gold/40 focus:outline-none focus:bg-steel-900 transition-all
                   placeholder-steel-600 rounded-none"
          />
          <button type="button" id="search-clear"
            class="absolute right-2 top-1/2 -translate-y-1/2 w-4 h-4 text-steel-500 hover:text-steel-300 hidden items-center justify-center">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
      </div>

      <!-- Results dropdown -->
      <div id="search-results"
        class="absolute left-4 right-4 sm:left-auto sm:right-auto sm:w-full sm:max-w-md top-full mt-1 z-30
               bg-steel-900 border border-steel-700 overflow-hidden
               max-h-0 opacity-0 pointer-events-none transition-all duration-200"
        style="box-shadow: 0 16px 40px rgba(0,0,0,0.7), 0 0 0 1px rgba(200,169,110,0.1);">
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    const allProducts = {
      {JSON.stringify(products.map(p => ({ id: p.id, title: p.title, category: p.category, compatible: p.compatible, features: p.features, image: p.image })))}
    };

    const input = document.getElementById('search-input');
    const results = document.getElementById('search-results');
    const clearBtn = document.getElementById('search-clear');
    let timer;

    function showResults(html) {
      results.innerHTML = html;
      results.style.maxHeight = '400px';
      results.style.opacity = '1';
      results.style.pointerEvents = 'auto';
    }

    function hideResults() {
      results.style.maxHeight = '0';
      results.style.opacity = '0';
      results.style.pointerEvents = 'none';
    }

    function getMatchTerms(query) {
      return query.toLowerCase().replace(/[-_/\s]+/g, ' ').trim().split(/\s+/).filter(Boolean);
    }

    function highlightMatch(text, terms) {
      if (!terms.length) return text;
      let html = text;
      terms.forEach(t => {
        const re = new RegExp(`(${t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
        html = html.replace(re, '<mark class="bg-crest-gold/20 text-crest-gold px-0.5">$1</mark>');
      });
      return html;
    }

    input.addEventListener('input', () => {
      clearTimeout(timer);
      const q = input.value.trim();
      if (q.length < 2) {
        hideResults();
        clearBtn.style.display = 'none';
        return;
      }
      clearBtn.style.display = 'flex';

      timer = setTimeout(() => {
        const terms = getMatchTerms(q);
        if (!terms.length) { hideResults(); return; }

        const matches = allProducts.map(p => {
          const searchText = [p.title, p.compatible, p.category, p.id, ...(p.features || [])].join(' ').toLowerCase();
          const score = terms.reduce((s, t) => {
            if (searchText.includes(t)) s += 3;
            const exactRe = new RegExp('\\b' + t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'i');
            if (exactRe.test(searchText)) s += 5;
            return s;
          }, 0);
          return { ...p, score };
        }).filter(p => p.score > 0).sort((a, b) => b.score - a.score).slice(0, 5);

        if (matches.length === 0) {
          showResults('<div class="px-4 py-6 text-center text-steel-500 text-xs">No products found for "' + q + '"</div>');
          return;
        }

        const html = matches.map(p => `
          <a href="/#products" onclick="document.getElementById('search-input').value='${p.id.replace(/'/g, "\\'")}'"
            class="flex items-start gap-3 px-3 sm:px-4 py-3 border-b border-steel-800/30 last:border-b-0
                   hover:bg-gradient-to-r hover:from-crest-gold/5 hover:to-transparent transition-colors cursor-pointer group">
            <div class="flex-shrink-0 w-10 h-10 bg-steel-950 border border-steel-800/50 flex items-center justify-center overflow-hidden">
              <span class="text-crest-gold text-[8px] tracking-wider font-bold uppercase">${p.category.slice(0, 3)}</span>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-steel-200 text-xs sm:text-sm font-medium group-hover:text-crest-gold transition-colors truncate">
                ${highlightMatch(p.title, terms)}
              </div>
              <div class="text-steel-500 text-[10px] sm:text-xs mt-0.5 truncate">
                ${highlightMatch(p.compatible, terms)}
              </div>
            </div>
          </a>
        `).join('');

        showResults(html);

        // Add click handlers to focus the product cards
        results.querySelectorAll('a').forEach(a => {
          a.addEventListener('click', function(e) {
            const pid = this.querySelector('span').textContent?.toLowerCase();
            hideResults();
            // Scroll to products section
            const section = document.getElementById('products');
            if (section) {
              section.scrollIntoView({ behavior: 'smooth' });
              // Flash effect on matching card
              setTimeout(() => {
                const card = document.querySelector(`[data-product-id="${p.id}"]`) ||
                  Array.from(document.querySelectorAll('.product-card')).find(c =>
                    c.textContent?.toLowerCase().includes(pid || '')
                  );
                if (card) {
                  card.style.transition = 'box-shadow 0.3s ease';
                  card.style.boxShadow = '0 0 24px rgba(200,169,110,0.3)';
                  setTimeout(() => { card.style.boxShadow = ''; }, 2000);
                }
              }, 400);
            }
          });
        });
      }, 250);
    });

    clearBtn.addEventListener('click', () => {
      input.value = '';
      input.focus();
      hideResults();
      clearBtn.style.display = 'none';
    });

    // Keyboard nav
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        hideResults();
        input.blur();
        clearBtn.style.display = 'none';
      }
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        input.focus();
      }
    });

    // Close on outside click
    document.addEventListener('click', function(e) {
      if (!e.target.closest('#header-search')) hideResults();
    });
  })();
</script>
