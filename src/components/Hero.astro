---
import { siteConfig } from '../data/products';
---

<section class="relative min-h-screen flex flex-col justify-center pt-24 pb-16 overflow-hidden">
  <!-- Storefront background -->
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src="/images/storefront.jpg"
      alt="Guangzhou YH Auto Parts Company"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-crest-dark/85 backdrop-blur-[2px]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_transparent_30%,_var(--crest-dark)_90%)]"></div>
  </div>
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 1px, #C8A96E 1px, #C8A96E 2px); background-size: 60px 60px;" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 text-center" dir="ltr">
    <div class="flex flex-col items-center gap-2 mb-8 sm:mb-12">
      <span data-i18n="hero.year" class="text-crest-gold text-[10px] sm:text-sm tracking-[0.3em] sm:tracking-[0.4em] font-medium uppercase">2018年 · 广州</span>
      <h1 class="text-3xl sm:text-5xl md:text-7xl font-display font-black tracking-tight leading-none">
        <span class="block text-steel-50">{siteConfig.brandName.split(' ')[0]}</span>
        <span class="block text-crest-gold">{siteConfig.brandName.split(' ').slice(1).join(' ')}</span>
      </h1>
      <div class="flex flex-col items-center gap-1 mt-3 sm:mt-4">
        <span class="block w-10 sm:w-12 h-px bg-crest-gold/60"></span>
        <span class="block w-6 sm:w-8 h-px bg-crest-gold/30"></span>
        <span class="block w-3 sm:w-4 h-px bg-crest-gold/20"></span>
      </div>
      <p class="text-steel-400 text-sm sm:text-lg max-w-xs sm:max-w-2xl mt-3 sm:mt-4 leading-relaxed px-2">
        {siteConfig.tagline}
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6 max-w-4xl mx-auto mt-12 sm:mt-16 text-left px-2">
      <div class="border-l-2 border-crest-gold/40 pl-3 sm:pl-4">
        <span data-i18n="hero.trust.markets" class="block text-crest-gold text-[10px] sm:text-xs tracking-widest uppercase mb-1">覆盖市场</span>
        <span data-i18n="hero.trust.marketsVal" class="block text-steel-200 text-xs sm:text-sm font-medium">东南亚 · 中东 · 非洲</span>
      </div>
      <div class="border-l-2 border-crest-gold/40 pl-3 sm:pl-4">
        <span data-i18n="hero.trust.quality" class="block text-crest-gold text-[10px] sm:text-xs tracking-widest uppercase mb-1">质量保证</span>
        <span data-i18n="hero.trust.qualityVal" class="block text-steel-200 text-xs sm:text-sm font-medium">原厂标准</span>
      </div>
      <div class="border-l-2 border-crest-gold/40 pl-3 sm:pl-4">
        <span data-i18n="hero.trust.shipping" class="block text-crest-gold text-[10px] sm:text-xs tracking-widest uppercase mb-1">运输方式</span>
        <span data-i18n="hero.trust.shippingVal" class="block text-steel-200 text-xs sm:text-sm font-medium">空运 / 海运 / 快递</span>
      </div>
      <div class="border-l-2 border-crest-gold/40 pl-3 sm:pl-4">
        <span data-i18n="hero.trust.moq" class="block text-crest-gold text-[10px] sm:text-xs tracking-widest uppercase mb-1">起订量</span>
        <span data-i18n="hero.trust.moqVal" class="block text-steel-200 text-xs sm:text-sm font-medium">灵活低门槛</span>
      </div>
    </div>

    <div class="mt-16 sm:mt-20 animate-bounce">
      <span data-i18n="hero.scroll" class="text-steel-600 text-[10px] sm:text-xs tracking-[0.3em] uppercase">向下滚动</span>
      <div class="flex flex-col items-center mt-2 gap-0.5">
        <span class="block w-px h-3 sm:h-4 bg-crest-gold/40"></span>
        <span class="block w-px h-2 sm:h-3 bg-crest-gold/20"></span>
      </div>
    </div>
  </div>
</section>
