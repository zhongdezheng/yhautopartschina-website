---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ContactBar from '../../components/ContactBar.astro';
import InquiryForm from '../../components/InquiryForm.astro';
import { pistons, pistonRings } from '../../data/products';

export function getStaticPaths() {
  const all = [...pistons, ...pistonRings];
  return all.map(p => ({ params: { id: p.id } }));
}

const { id } = Astro.params;
const allProducts = [...pistons, ...pistonRings];
const product = allProducts.find(p => p.id === id);

if (!product) {
  return new Response('Not Found', { status: 404 });
}

const details = product.details ? (typeof product.details === 'string' ? JSON.parse(product.details) : product.details) : null;
---

<Layout title={`${product.title} — YH AUTO PARTS`} description={`${product.title} — ${product.compatible}. OEM quality auto parts from Guangzhou, China.`}>
  <Header />
  <ContactBar />

  <main class="pt-28 md:pt-32 pb-16">
    <!-- Breadcrumb -->
    <section class="px-4 sm:px-6 py-4">
      <div class="mx-auto max-w-5xl">
        <nav class="flex items-center gap-2 text-[10px] sm:text-xs text-steel-500">
          <a href="/" class="lang-link hover:text-crest-gold transition-colors">首页</a>
          <span>/</span>
          <a href="/pistons" class="lang-link hover:text-crest-gold transition-colors">活塞</a>
          <span>/</span>
          <span class="text-steel-300">{product.title}</span>
        </nav>
      </div>
    </section>

    <!-- Product Hero -->
    <section class="px-4 sm:px-6 py-8 md:py-12">
      <div class="mx-auto max-w-5xl grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
        <!-- Image -->
        <div class="bg-steel-950 border border-steel-800/50 overflow-hidden">
          {product.image ? (
            <img src={product.image} alt={product.title} class="w-full aspect-square object-cover" loading="eager" />
          ) : (
            <div class="w-full aspect-square flex items-center justify-center text-steel-700 text-sm bg-steel-950">产品图片待更新</div>
          )}
        </div>

        <!-- Info -->
        <div class="flex flex-col gap-5">
          <div>
            <span class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase">{product.category}</span>
            <h1 class="text-2xl sm:text-3xl font-display font-black text-steel-50 mt-2">{product.title}</h1>
            <p class="text-steel-400 text-sm mt-3">
              <span class="text-steel-500">适配车型:</span> {product.compatible}
            </p>
          </div>

          {product.features && product.features.length > 0 && (
            <div>
              <h3 class="text-xs text-steel-400 tracking-wider uppercase mb-2">产品特点</h3>
              <div class="flex flex-wrap gap-2">
                {product.features.map(f => (
                  <span class="text-[10px] sm:text-xs px-3 py-1 border border-crest-gold/30 text-crest-gold">{f}</span>
                ))}
              </div>
            </div>
          )}

          {details && (
            <div class="space-y-4">
              {details.oem && details.oem.length > 0 && (
                <div>
                  <h3 class="text-xs text-crest-gold tracking-widest uppercase font-semibold mb-2">OEM No.</h3>
                  <div class="text-steel-400 text-sm leading-relaxed bg-steel-950/50 border border-steel-800/30 p-3">
                    {details.oem.map(line => <div class="py-0.5">{line}</div>)}
                  </div>
                </div>
              )}
              {details.size && details.size.length > 0 && (
                <div>
                  <h3 class="text-xs text-crest-gold tracking-widest uppercase font-semibold mb-2">Size / Specs</h3>
                  <div class="text-steel-400 text-sm leading-relaxed bg-steel-950/50 border border-steel-800/30 p-3">
                    {details.size.map(line => <div class="py-0.5">{line}</div>)}
                  </div>
                </div>
              )}
              {details.used && details.used.length > 0 && (
                <div>
                  <h3 class="text-xs text-crest-gold tracking-widest uppercase font-semibold mb-2">Used For</h3>
                  <div class="text-steel-400 text-sm leading-relaxed bg-steel-950/50 border border-steel-800/30 p-3">
                    {details.used.map(line => <div class="py-0.5">{line}</div>)}
                  </div>
                </div>
              )}
            </div>
          )}

          <div class="mt-auto pt-4">
            <a href="#inquiry" class="inline-flex items-center gap-2 px-6 py-3 bg-crest-gold text-crest-dark font-semibold text-sm tracking-wider uppercase hover:bg-crest-gold/90 transition-colors">
              发送询盘 →
            </a>
          </div>
        </div>
      </div>
    </section>

    <InquiryForm />

    <!-- Footer -->
    <footer class="px-4 sm:px-6 py-12 md:py-16 text-center">
      <div class="flex flex-col items-center gap-3">
        <div class="flex flex-col items-center leading-none">
          <span class="text-crest-gold text-sm tracking-[0.3em] font-medium uppercase">YH</span>
          <span class="text-steel-500 text-[10px] tracking-[0.5em] uppercase">AUTO PARTS</span>
        </div>
        <span class="block w-8 h-px bg-crest-gold/30"></span>
        <p class="text-steel-600 text-xs tracking-wider">广州 · 中国</p>
        <p class="text-steel-700 text-[10px] tracking-wider">活塞及活塞环专家 · 服务东南亚、中东及非洲市场</p>
      </div>
    </footer>
  </main>
</Layout>

<script is:inline>
  (function() {
    var p = new URLSearchParams(window.location.search);
    var curLang = p.get('lang');
    if (!curLang) return;
    document.querySelectorAll('a.lang-link').forEach(function(a) {
      try {
        var url = new URL(a.href, window.location.origin);
        url.searchParams.set('lang', curLang);
        a.href = url.pathname + url.search;
      } catch(e) {}
    });
  })();
</script>
