---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProductCard from '../components/ProductCard.astro';
import ContactBar from '../components/ContactBar.astro';
import InquiryForm from '../components/InquiryForm.astro';
import { pistons } from '../data/products';
---

<Layout title="活塞 — YH AUTO PARTS" description="Complete piston catalog for SEA, Middle East & Africa.">
  <Header />
  <ContactBar />

  <main class="pt-28 md:pt-32 pb-16">
    <section class="px-4 sm:px-6 py-12 md:py-16">
      <div class="mx-auto max-w-7xl text-center">
        <span class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase mb-2 inline-block">Pistons</span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-black text-steel-50">全部活塞产品</h1>
        <div class="flex flex-col items-center gap-0.5 mt-4">
          <span class="block w-10 h-px bg-crest-gold/50"></span>
          <span class="block w-6 h-px bg-crest-gold/20"></span>
        </div>
        <p class="text-steel-400 text-sm mt-6 max-w-xl mx-auto">浏览完整的活塞产品目录。现货库存，支持批发与样品订单。</p>
      </div>
    </section>

    <section class="px-4 sm:px-6 py-8 md:py-12 bg-steel-950/30">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 md:gap-8" id="pistons-grid">
          {pistons.map((product, i) => (
            <ProductCard product={product} index={i} />
          ))}
        </div>
      </div>
    </section>

    <InquiryForm />
    <footer class="px-4 sm:px-6 py-12 md:py-16 text-center">
      <div class="flex flex-col items-center gap-3">
        <div class="flex flex-col items-center leading-none">
          <span class="text-crest-gold text-sm tracking-[0.3em] font-medium uppercase">YH</span>
          <span class="text-steel-500 text-[10px] tracking-[0.5em] uppercase">AUTO PARTS</span>
        </div>
        <span class="block w-8 h-px bg-crest-gold/30"></span>
        <p class="text-steel-600 text-xs tracking-wider">广州 · 中国</p>
        <p class="text-steel-700 text-[10px] tracking-wider">活塞及活塞环专家</p>
      </div>
    </footer>
  </main>
</Layout>

<script is:inline>
  // Load pistons from API into the grid (replaces static 4 with all from DB)
  (async function() {
    try {
      const res = await fetch('/api/products');
      if (!res.ok) return;
      const data = await res.json();
      const apiPistons = (data || []).filter(p => p.category !== '活塞环');
      if (!apiPistons.length) return;
      const grid = document.getElementById('pistons-grid');
      if (!grid) return;
      grid.innerHTML = apiPistons.map((p, i) => {
        const details = typeof p.details === 'string' ? JSON.parse(p.details||'{}') : (p.details || {});
        const imgHtml = p.image ? `<img src="${p.image}" alt="${p.title}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />` : `<div class="w-full h-full flex items-center justify-center text-steel-700 text-xs">暂无图片</div>`;
        const oemHtml = (details.oem||[]).length ? `<div class="detail-section"><div class="flex items-center gap-2 mb-1.5"><span class="text-[11px] text-crest-gold tracking-widest uppercase font-semibold">OEM No.</span><span class="h-px flex-1 bg-crest-gold/20"></span></div><div class="text-steel-400 text-xs leading-relaxed">${details.oem.slice(0,3).join('<br>')}</div></div>` : '';
        const usedHtml = (details.used||[]).length ? `<div class="detail-section mt-3"><div class="flex items-center gap-2 mb-1"><span class="text-[11px] text-crest-gold tracking-widest uppercase font-semibold">Used For</span><span class="h-px flex-1 bg-crest-gold/20"></span></div><div class="text-steel-400 text-xs leading-relaxed">${details.used.slice(0,3).join('<br>')}</div></div>` : '';
        const seriesTag = details.series ? `<span class="absolute bottom-2 right-2 bg-crest-dark/80 text-crest-gold text-[10px] px-2 py-0.5">${details.series}</span>` : '';
        return `<a href="/product/${p.id}" class="product-card group border border-steel-800/60 hover:border-crest-gold/30 bg-steel-950/50 transition-all duration-500 block no-underline">
          <div class="aspect-[4/3] overflow-hidden relative bg-steel-950">
            ${imgHtml}
            <div class="absolute top-0 left-0 bg-crest-gold text-crest-dark text-[10px] px-2 py-0.5 tracking-wider uppercase font-semibold">${p.category}</div>
            ${seriesTag}
          </div>
          <div class="p-4 sm:p-5">
            <h3 class="text-steel-100 text-sm sm:text-base font-semibold leading-snug mb-2 group-hover:text-crest-gold transition-colors">${p.title}</h3>
            ${oemHtml}${usedHtml}
            <p class="text-steel-500 text-[10px] text-xs mt-3">${p.compatible}</p>
          </div>
        </a>`;
      }).join('');
    } catch(e) {}
  })();
</script>
