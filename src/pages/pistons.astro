---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProductCard from '../components/ProductCard.astro';
import ContactBar from '../components/ContactBar.astro';
import InquiryForm from '../components/InquiryForm.astro';
import { pistons } from '../data/products';
---

<Layout title="活塞 — YH AUTO PARTS" description="Browse our complete piston catalog for SEA, Middle East & Africa markets.">
  <Header />
  <ContactBar />

  <main class="pt-28 md:pt-32">
    <!-- Piston Page Hero -->
    <section class="px-4 sm:px-6 py-12 md:py-16">
      <div class="mx-auto max-w-7xl text-center">
        <span class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase mb-2 inline-block">Pistons</span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-display font-black text-steel-50">全部活塞产品</h1>
        <div class="flex flex-col items-center gap-0.5 mt-4">
          <span class="block w-10 h-px bg-crest-gold/50"></span>
          <span class="block w-6 h-px bg-crest-gold/20"></span>
        </div>
        <p class="text-steel-400 text-sm mt-6 max-w-xl mx-auto">浏览我们完整的活塞产品目录。所有产品均为现货库存，支持批发与样品订单。</p>
      </div>
    </section>

    <!-- All Pistons Grid -->
    <section class="px-4 sm:px-6 py-8 md:py-12 bg-steel-950/30">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 md:gap-8">
          {pistons.map((product, i) => (
            <ProductCard product={product} index={i} />
          ))}
        </div>

        {pistons.length === 0 && (
          <div class="text-center py-16">
            <p class="text-steel-500">暂无产品，敬请期待。</p>
          </div>
        )}
      </div>
    </section>

    <InquiryForm />

    <!-- Footer -->
    <footer class="px-4 sm:px-6 py-12 md:py-16 text-center">
      <div class="flex flex-col items-center gap-3">
        <div class="flex flex-col items-center leading-none">
          <span class="text-crest-gold text-sm tracking-[0.3em] font-medium uppercase">YH</span>
          <span class="text-steel-500 text-[10px] tracking-[0.5em] uppercase">AUTO PARTS</span>
        </div>
        <span class="block w-8 h-px bg-crest-gold/30"></span>
        <p class="text-steel-600 text-xs tracking-wider">广州 · 中国</p>
        <p class="text-steel-700 text-[10px] tracking-wider">活塞及活塞环专家 · 服务东南亚、中东及非洲市场</p>
      </div>
    </footer>
  </main>
</Layout>
