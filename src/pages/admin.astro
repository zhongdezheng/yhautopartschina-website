---
// Admin page at /admin
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Admin — YH Auto Parts</title>
  <style is:inline>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #0a0a10; color: #d0d0d8;
      min-height: 100vh;
    }
    .container { max-width: 1100px; margin: 0 auto; padding: 24px 16px; }
    h1 { font-size: 1.4rem; font-weight: 700; color: #c8a96e; margin-bottom: 4px; }
    h2 { font-size: 1.1rem; font-weight: 600; margin: 24px 0 12px; color: #e0e0e8; }
    .muted { font-size: 0.75rem; color: #666; }

    /* Login */
    .login-box {
      max-width: 360px; margin: 80px auto; padding: 32px;
      background: #111118; border: 1px solid #2a2a38;
      text-align: center;
    }
    .login-box input {
      width: 100%; margin-top: 12px; padding: 10px 14px;
      background: #1a1a24; border: 1px solid #333; color: #d0d0d8;
      font-size: 0.9rem; outline: none;
    }
    .login-box input:focus { border-color: #c8a96e; }

    /* Buttons */
    .btn {
      padding: 8px 18px; font-size: 0.8rem; border: 1px solid #333;
      background: #1a1a24; color: #d0d0d8; cursor: pointer;
      transition: all 0.2s; text-transform: uppercase; letter-spacing: 0.05em;
    }
    .btn:hover { border-color: #c8a96e; color: #c8a96e; }
    .btn-primary { background: #c8a96e; color: #0a0a10; border-color: #c8a96e; }
    .btn-primary:hover { background: #b8985e; color: #0a0a10; }
    .btn-danger { border-color: #8b3a3a; color: #d47272; }
    .btn-danger:hover { background: #3a1a1a; border-color: #d44; }
    .btn-sm { padding: 4px 12px; font-size: 0.7rem; }

    /* Table */
    table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    th, td { padding: 10px 12px; text-align: left; border-bottom: 1px solid #1a1a28; }
    th { color: #888; font-weight: 500; text-transform: uppercase; font-size: 0.65rem; letter-spacing: 0.1em; }
    tr:hover td { background: rgba(200,169,110,0.03); }
    .img-cell { width: 60px; }
    .img-cell img { width: 48px; height: 48px; object-fit: cover; background: #111; border: 1px solid #222; }
    .tag { display: inline-block; padding: 2px 8px; font-size: 0.65rem; border: 1px solid #333; color: #888; margin: 1px 2px; }
    .tag.gold { border-color: #c8a96e40; color: #c8a96e; }

    /* Modal */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.2s;
    }
    .modal-overlay.active { opacity: 1; pointer-events: auto; }
    .modal {
      background: #111118; border: 1px solid #2a2a38; padding: 28px;
      width: 90%; max-width: 580px; max-height: 80vh; overflow-y: auto;
    }
    .modal h3 { font-size: 1rem; margin-bottom: 20px; color: #c8a96e; }
    .field { margin-bottom: 14px; }
    .field label { display: block; font-size: 0.7rem; color: #888; text-transform: uppercase; margin-bottom: 4px; letter-spacing: 0.08em; }
    .field input, .field textarea, .field select {
      width: 100%; padding: 8px 12px; background: #1a1a24; border: 1px solid #333;
      color: #d0d0d8; font-size: 0.85rem; outline: none;
    }
    .field input:focus, .field textarea:focus { border-color: #c8a96e; }
    .field textarea { min-height: 60px; resize: vertical; }

    .toast {
      position: fixed; top: 20px; right: 20px; z-index: 200;
      padding: 12px 20px; font-size: 0.8rem; border: 1px solid;
      opacity: 0; transition: opacity 0.3s; pointer-events: none;
    }
    .toast.show { opacity: 1; }
    .toast.success { background: #0a1a0a; border-color: #2a6a2a; color: #6ad46a; }
    .toast.error { background: #1a0a0a; border-color: #6a2a2a; color: #d46a6a; }
  </style>
</head>
<body>

<div id="login-screen" class="login-box">
  <h1 style="font-size:1.2rem">YH Admin</h1>
  <p class="muted" style="margin-bottom:16px">Product Management</p>
  <input type="password" id="login-token" placeholder="Admin Token" onkeydown="if(event.key==='Enter')login()" />
  <button class="btn btn-primary" style="width:100%;margin-top:12px" onclick="login()">Login</button>
</div>

<div id="main-screen" style="display:none">
  <div class="container">
    <div style="display:flex;justify-content:space-between;align-items:center">
      <div>
        <h1>YH Admin</h1>
        <p class="muted">Product Management · <a href="/" style="color:#c8a96e;text-decoration:none">View Site →</a></p>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-primary" onclick="openModal()">+ New Product</button>
        <button class="btn btn-sm" onclick="logout()" style="border-color:#444">Logout</button>
      </div>
    </div>

    <h2>Products (<span id="product-count">0</span>)</h2>
    <div id="table-wrap" style="overflow-x:auto">
      <table>
        <thead><tr>
          <th></th><th>Title</th><th>Category</th><th>Compatible</th><th>Markets</th><th></th>
        </tr></thead>
        <tbody id="product-list"><tr><td colspan="6" style="text-align:center;color:#555">Loading...</td></tr></tbody>
      </table>
    </div>
  </div>
</div>

<!-- Product Edit Modal -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <h3 id="modal-title">New Product</h3>
    <form id="product-form" onsubmit="saveProduct(event)">
      <div class="field">
        <label>Title *</label>
        <input type="text" id="f-title" required placeholder="e.g. BMW B48 Piston Kit" />
      </div>
      <div class="field">
        <label>Category *</label>
        <input type="text" id="f-category" required placeholder="e.g. Piston Kit" />
      </div>
      <div class="field">
        <label>Compatible Vehicles *</label>
        <textarea id="f-compatible" required placeholder="e.g. BMW 3-Series, 5-Series, X3 (2015-2022)"></textarea>
      </div>
      <div class="field">
        <label>Features (one per line)</label>
        <textarea id="f-features" placeholder="OEM quality&#10;1 year warranty&#10;Fast shipping"></textarea>
      </div>
      <div class="field">
        <label>Image Path</label>
        <input type="text" id="f-image" placeholder="e.g. /images/new_part.jpg or URL" />
      </div>
      <div class="field">
        <label>Market Focus (comma separated)</label>
        <input type="text" id="f-markets" placeholder="e.g. Southeast Asia, Middle East, Africa" />
      </div>
      <div style="display:flex;gap:8px;margin-top:20px">
        <button type="submit" class="btn btn-primary" id="btn-save">Save Product</button>
        <button type="button" class="btn" onclick="closeModal()">Cancel</button>
        <button type="button" class="btn btn-danger" id="btn-delete" style="display:none;margin-left:auto" onclick="deleteProduct()">Delete</button>
      </div>
    </form>
  </div>
</div>

<div class="toast" id="toast"></div>

<script is:inline>
  let token = localStorage.getItem('yh_admin_token');
  let products = [];
  let editingId = null;

  if (token) { showMain(); loadProducts(); } else { document.getElementById('login-screen').style.display = 'block'; }

  function login() {
    token = document.getElementById('login-token').value.trim();
    if (!token) return toast('Please enter token', 'error');
    fetch('/api/products', { headers: { Authorization: 'Bearer ' + token } })
      .then(r => {
        if (r.ok) { localStorage.setItem('yh_admin_token', token); showMain(); loadProducts(); }
        else toast('Invalid token', 'error');
      }).catch(() => toast('Connection failed', 'error'));
  }

  function logout() {
    localStorage.removeItem('yh_admin_token');
    token = null;
    document.getElementById('login-screen').style.display = 'block';
    document.getElementById('main-screen').style.display = 'none';
  }

  function showMain() {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('main-screen').style.display = 'block';
  }

  async function loadProducts() {
    try {
      const r = await fetch('/api/products');
      products = await r.json();
      renderTable();
    } catch { document.getElementById('product-list').innerHTML = '<tr><td colspan="6" style="text-align:center;color:#a44">Failed to load</td></tr>'; }
  }

  function renderTable() {
    document.getElementById('product-count').textContent = products.length;
    const tbody = document.getElementById('product-list');
    if (!products.length) {
      tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:40px;color:#555">No products yet. Click "+ New Product"</td></tr>';
      return;
    }
    tbody.innerHTML = products.map(p => `
      <tr>
        <td class="img-cell">${p.image ? `<img src="${p.image}" alt="" />` : '<div style="width:48px;height:48px;background:#111;border:1px solid #222;display:flex;align-items:center;justify-content:center;color:#444;font-size:10px">N/A</div>'}</td>
        <td><strong style="color:#e0e0e8">${esc(p.title)}</strong></td>
        <td><span class="tag gold">${esc(p.category)}</span></td>
        <td style="font-size:0.75rem;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(p.compatible)}</td>
        <td>${(p.market_focus||[]).map(m => `<span class="tag">${esc(m)}</span>`).join(' ')}</td>
        <td><button class="btn btn-sm" onclick="editProduct('${p.id}')">Edit</button></td>
      </tr>
    `).join('');
  }

  function openModal(id) {
    editingId = id || null;
    document.getElementById('modal-title').textContent = id ? 'Edit Product' : 'New Product';
    document.getElementById('btn-delete').style.display = id ? 'inline-block' : 'none';
    document.getElementById('f-title').value = '';
    document.getElementById('f-category').value = '';
    document.getElementById('f-compatible').value = '';
    document.getElementById('f-features').value = '';
    document.getElementById('f-image').value = '';
    document.getElementById('f-markets').value = '';

    if (id) {
      const p = products.find(x => x.id === id);
      if (p) {
        document.getElementById('f-title').value = p.title;
        document.getElementById('f-category').value = p.category;
        document.getElementById('f-compatible').value = p.compatible;
        document.getElementById('f-features').value = (p.features||[]).join('\n');
        document.getElementById('f-image').value = p.image || '';
        document.getElementById('f-markets').value = (p.market_focus||[]).join(', ');
      }
    }

    document.getElementById('modal').classList.add('active');
  }

  function closeModal() {
    document.getElementById('modal').classList.remove('active');
    editingId = null;
  }

  async function saveProduct(e) {
    e.preventDefault();
    const data = {
      title: document.getElementById('f-title').value.trim(),
      category: document.getElementById('f-category').value.trim(),
      compatible: document.getElementById('f-compatible').value.trim(),
      features: document.getElementById('f-features').value.split('\n').map(s => s.trim()).filter(Boolean),
      image: document.getElementById('f-image').value.trim(),
      marketFocus: document.getElementById('f-markets').value.split(',').map(s => s.trim()).filter(Boolean),
    };
    if (editingId) data.id = editingId;

    const url = editingId ? `/api/products?id=${editingId}` : '/api/products';
    const method = editingId ? 'PUT' : 'POST';

    try {
      const r = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
        body: JSON.stringify(data),
      });
      if (!r.ok) throw new Error((await r.json()).error || 'Save failed');
      toast(editingId ? 'Product updated' : 'Product created', 'success');
      closeModal();
      loadProducts();
    } catch(err) {
      toast(err.message, 'error');
    }
  }

  function editProduct(id) { openModal(id); }

  async function deleteProduct() {
    if (!confirm('Delete this product permanently?')) return;
    try {
      const r = await fetch(`/api/products?id=${editingId}`, {
        method: 'DELETE',
        headers: { Authorization: 'Bearer ' + token },
      });
      if (!r.ok) throw new Error('Delete failed');
      toast('Product deleted', 'success');
      closeModal();
      loadProducts();
    } catch(err) {
      toast(err.message, 'error');
    }
  }

  function toast(msg, type) {
    const el = document.getElementById('toast');
    el.textContent = msg; el.className = 'toast ' + type + ' show';
    setTimeout(() => el.classList.remove('show'), 2500);
  }

  function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  // Click outside modal
  document.getElementById('modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
</script>
</body>
</html>
