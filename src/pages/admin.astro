async function batchImportPistons() {
  var btn = document.getElementById('btn-batch-import');
  var prog = document.getElementById('import-progress');
  var logEl = document.getElementById('import-log');
  btn.disabled = true;
  logEl.innerHTML = '';
  var ok = 0, fail = 0;
  for (var i = 0; i < __pistonData.length; i++) {
    var p = __pistonData[i];
    try {
      var r = await fetch('/api/products', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Authorization: '***' + token },
        body: JSON.stringify(p)
      });
      if (r.ok) ok++;
      else fail++;
      if ((i+1) % 10 === 0 || i === __pistonData.length - 1) {
        prog.textContent = (i+1) + '/' + __pistonData.length + ' ok=' + ok + ' fail=' + fail;
      }
    } catch(e) { fail++; }
  }
  logEl.innerHTML += '<div style="color:#6ad46a">✓ 导入完成: ' + ok + ' 成功, ' + fail + ' 失败</div>';
  prog.textContent = '完成! 刷新页面查看';
  btn.disabled = false;
  loadProducts();
}

// Show import panel if piston tab is empty
var __origSwitchTab = switchTab;
switchTab = function(t) {
  __origSwitchTab(t);
  if (t === 'pistons') {
    document.getElementById('import-batch-panel').style.display = 'block';
  } else {
    document.getElementById('import-batch-panel').style.display = 'none';
  }
};
// Also show after login
var __origShowMain = showMain;
showMain = function() {
  __origShowMain();
  if (tab === 'pistons') document.getElementById('import-batch-panel').style.display = 'block';
};
