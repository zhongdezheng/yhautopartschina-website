---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import ThreeViewer from '../components/ThreeViewer.astro';
import InquiryForm from '../components/InquiryForm.astro';
import ContactBar from '../components/ContactBar.astro';
import { products, siteConfig } from '../data/products';
---

<Layout>
  <Header />
  <ContactBar />

  <main>
    <Hero />

    <!-- 3D Viewer -->
    <section class="px-4 sm:px-6 py-16 md:py-24">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col items-center mb-10 md:mb-14 text-center">
          <span data-i18n="3d.section" class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase mb-2">3D互动</span>
          <h2 data-i18n="3d.heading" class="text-2xl sm:text-3xl md:text-4xl font-display font-black text-steel-50">3D 活塞探索器</h2>
          <div class="flex flex-col items-center gap-0.5 mt-3">
            <span class="block w-10 h-px bg-crest-gold/50"></span>
            <span class="block w-6 h-px bg-crest-gold/20"></span>
          </div>
        </div>
        <ThreeViewer />
      </div>
    </section>

    <!-- Products Grid -->
    <section id="products" class="px-4 sm:px-6 py-16 md:py-24 bg-steel-950/30">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col items-center mb-10 md:mb-16 text-center">
          <span data-i18n="products.section" class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase mb-2">现货库存</span>
          <h2 data-i18n="products.heading" class="text-2xl sm:text-3xl md:text-4xl font-display font-black text-steel-50">产品系列</h2>
          <div class="flex flex-col items-center gap-0.5 mt-3">
            <span class="block w-10 h-px bg-crest-gold/50"></span>
            <span class="block w-6 h-px bg-crest-gold/20"></span>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-8" id="products-grid">
          {products.map((product, i) => (
            <ProductCard product={product} index={i} />
          ))}
        </div>
      </div>
    </section>

    <InquiryForm />

    <script is:inline>
      // Dynamic product loading from API
      (async function() {
        try {
          const res = await fetch('/api/products');
          if (!res.ok) return;
          const apiProducts = await res.json();
          if (!apiProducts.length) return;
          
          const grid = document.getElementById('products-grid');
          const langs = {
            zh: '适配车型', en: 'Compatible', ru: 'Совместимость', ar: 'متوافق مع', vi: 'Tương thích', th: 'เข้ากันได้กับ'
          };
          const p = new URLSearchParams(window.location.search);
          const lang = langs[p.get('lang')] || langs.zh;
          
          grid.innerHTML = apiProducts.map((p) => {
            const details = p.details || {};
            const hasOem = details.oem && details.oem.length > 0;
            const hasSize = details.size && details.size.length > 0;
            const hasUsed = details.used && details.used.length > 0;
            const hasDetails = hasOem || hasSize || hasUsed;
            const uid = 'd' + Math.random().toString(36).slice(2,8);

            function sectionHTML(title, lines, id) {
              if (!lines || !lines.length) return '';
              const visible = lines.slice(0, 3);
              const hidden = lines.slice(3);
              const hasMore = hidden.length > 0;
              const dataId = uid + '-' + id;
              return `
                <div class="detail-section mt-2">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="text-[9px] text-crest-gold tracking-widest uppercase font-semibold">${title}</span>
                    <span class="h-px flex-1 bg-crest-gold/20"></span>
                  </div>
                  <div class="text-steel-400 text-[10px] leading-relaxed" data-section="${dataId}">
                    ${visible.map(l => '<div>' + escHtml(l) + '</div>').join('')}
                  </div>
                  ${hasMore ? `
                  <div class="text-steel-400 text-[10px] leading-relaxed hidden" data-section="${dataId}-more">
                    ${hidden.map(l => '<div>' + escHtml(l) + '</div>').join('')}
                  </div>
                  <button class="detail-more-btn text-[9px] text-crest-gold/60 hover:text-crest-gold mt-0.5 tracking-wider uppercase transition-colors" data-target="${dataId}">+ More</button>` : ''}
                </div>`;
            }

            return `
            <article class="product-card group border border-steel-800/60 hover:border-crest-gold/30 bg-steel-950/50 transition-all duration-500" data-product-id="${p.id}">
              <div class="aspect-[4/3] overflow-hidden relative bg-steel-950">
                ${p.image ? `<img src="${escHtml(p.image)}" alt="${escHtml(p.title)}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />` : '<div class="w-full h-full flex items-center justify-center text-steel-700 text-xs">暂无图片</div>'}
                <div class="absolute top-0 left-0 bg-crest-gold text-crest-dark text-[10px] px-2 py-0.5 tracking-wider uppercase font-semibold">${escHtml(p.category)}</div>
              </div>
              <div class="p-4 sm:p-5">
                <h3 class="text-steel-100 text-sm sm:text-base font-semibold leading-snug mb-2 group-hover:text-crest-gold transition-colors">${escHtml(p.title)}</h3>
                ${hasDetails
                  ? sectionHTML('OEM No.', details.oem, 'oem') + sectionHTML('Size / Specs', details.size, 'size') + sectionHTML('Used For', details.used, 'used')
                  : `<p class="text-steel-500 text-[10px] sm:text-xs leading-relaxed mb-3"><span class="text-steel-400 font-medium">${lang}:</span> ${escHtml(p.compatible)}</p>${p.features && p.features.length ? '<div class="flex flex-wrap gap-1.5">' + p.features.map(f => `<span class="text-[9px] sm:text-[10px] px-2 py-0.5 border border-steel-800 text-steel-400">${escHtml(f)}</span>`).join('') + '</div>' : ''}`
                }
              </div>
            </article>`;
          }).join('');

          // Add click handlers for More/Less buttons
          grid.querySelectorAll('.detail-more-btn').forEach(btn => {
            btn.addEventListener('click', function() {
              const target = this.dataset.target;
              const moreEl = grid.querySelector(`[data-section="${target}-more"]`);
              if (moreEl) {
                const hidden = moreEl.classList.toggle('hidden');
                this.textContent = hidden ? '+ More' : '- Less';
              }
            });
          });
          function escHtml(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
        } catch(e) { /* keep static content */ }
      })();
    </script>

    <!-- Payment -->
    <section class="px-4 sm:px-6 py-16 md:py-20 border-y border-steel-800/20">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col items-center mb-10 text-center">
          <span data-i18n="payment.section" class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase mb-2">支付方式</span>
          <h2 data-i18n="payment.heading" class="text-xl sm:text-2xl md:text-3xl font-display font-black text-steel-50">我们接受</h2>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7 gap-3 md:gap-4">
          {siteConfig.paymentMethods.map((pm) => (
            <div class="flex flex-col items-center gap-2 p-4 border border-steel-800/40 hover:border-crest-gold/20 bg-steel-950/30 transition-colors">
              <span class="text-crest-gold text-lg md:text-xl font-mono tracking-wider">{pm.name.slice(0, 2).toUpperCase()}</span>
              <span class="text-steel-400 text-[10px] md:text-xs tracking-wider text-center leading-tight">{pm.name}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-4 sm:px-6 py-12 md:py-16 text-center">
      <div class="flex flex-col items-center gap-3">
        <div class="flex flex-col items-center leading-none">
          <span class="text-crest-gold text-sm tracking-[0.3em] font-medium uppercase">{siteConfig.brandName.split(' ')[0]}</span>
          <span class="text-steel-500 text-[10px] tracking-[0.5em] uppercase">{siteConfig.brandName.split(' ').slice(1).join(' ')}</span>
        </div>
        <span class="block w-8 h-px bg-crest-gold/30"></span>
        <p data-i18n="footer.copyright" class="text-steel-600 text-xs tracking-wider">广州 · 中国</p>
        <p data-i18n="footer.tagline" class="text-steel-700 text-[10px] tracking-wider">活塞及活塞环专家 · 服务东南亚、中东及非洲市场</p>
      </div>
    </footer>
  </main>
</Layout>
