---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';
import ThreeViewer from '../components/ThreeViewer.astro';
import InquiryForm from '../components/InquiryForm.astro';
import ContactBar from '../components/ContactBar.astro';
import { products, siteConfig } from '../data/products';
---

<Layout>
  <Header />
  <ContactBar />

  <main>
    <Hero />

    <!-- 3D Viewer -->
    <section class="px-4 sm:px-6 py-16 md:py-24">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col items-center mb-10 md:mb-14 text-center">
          <span data-i18n="3d.section" class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase mb-2">3D互动</span>
          <h2 data-i18n="3d.heading" class="text-2xl sm:text-3xl md:text-4xl font-display font-black text-steel-50">3D 活塞探索器</h2>
          <div class="flex flex-col items-center gap-0.5 mt-3">
            <span class="block w-10 h-px bg-crest-gold/50"></span>
            <span class="block w-6 h-px bg-crest-gold/20"></span>
          </div>
          <p data-i18n="3d.subtitle" class="text-steel-500 text-sm md:text-base max-w-xl mt-4">旋转、检查、分解组件。真实 GLTF 模型即将上线。</p>
        </div>
        <ThreeViewer />
      </div>
    </section>

    <!-- Products Grid -->
    <section id="products" class="px-4 sm:px-6 py-16 md:py-24 bg-steel-950/30">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col items-center mb-10 md:mb-16 text-center">
          <span data-i18n="products.section" class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase mb-2">现货库存</span>
          <h2 data-i18n="products.heading" class="text-2xl sm:text-3xl md:text-4xl font-display font-black text-steel-50">产品系列</h2>
          <div class="flex flex-col items-center gap-0.5 mt-3">
            <span class="block w-10 h-px bg-crest-gold/50"></span>
            <span class="block w-6 h-px bg-crest-gold/20"></span>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-8">
          {products.map((product, i) => (
            <ProductCard product={product} index={i} />
          ))}
        </div>
      </div>
    </section>

    <InquiryForm />

    <!-- Payment -->
    <section class="px-4 sm:px-6 py-16 md:py-20 border-y border-steel-800/20">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col items-center mb-10 text-center">
          <span data-i18n="payment.section" class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase mb-2">支付方式</span>
          <h2 data-i18n="payment.heading" class="text-xl sm:text-2xl md:text-3xl font-display font-black text-steel-50">我们接受</h2>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7 gap-3 md:gap-4">
          {siteConfig.paymentMethods.map((pm) => (
            <div class="flex flex-col items-center gap-2 p-4 border border-steel-800/40 hover:border-crest-gold/20 bg-steel-950/30 transition-colors">
              <span class="text-crest-gold text-lg md:text-xl font-mono tracking-wider">{pm.name.slice(0, 2).toUpperCase()}</span>
              <span class="text-steel-400 text-[10px] md:text-xs tracking-wider text-center leading-tight">{pm.name}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-4 sm:px-6 py-12 md:py-16 text-center">
      <div class="flex flex-col items-center gap-3">
        <div class="flex flex-col items-center leading-none">
          <span class="text-crest-gold text-sm tracking-[0.3em] font-medium uppercase">{siteConfig.brandName.split(' ')[0]}</span>
          <span class="text-steel-500 text-[10px] tracking-[0.5em] uppercase">{siteConfig.brandName.split(' ').slice(1).join(' ')}</span>
        </div>
        <span class="block w-8 h-px bg-crest-gold/30"></span>
        <p data-i18n="footer.copyright" class="text-steel-600 text-xs tracking-wider">广州 · 中国</p>
        <p data-i18n="footer.tagline" class="text-steel-700 text-[10px] tracking-wider">活塞及活塞环专家 · 服务东南亚、中东及非洲市场</p>
      </div>
    </footer>
  </main>
</Layout>
