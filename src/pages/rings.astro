---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProductCard from '../components/ProductCard.astro';
import ContactBar from '../components/ContactBar.astro';
---

<Layout>
  <Header />
  <ContactBar />

  <main class="pt-24">
    <!-- Hero Banner -->
    <section class="px-4 sm:px-6 py-12 md:py-20">
      <div class="mx-auto max-w-5xl text-center">
        <span class="text-crest-gold text-[10px] sm:text-xs tracking-[0.3em] uppercase mb-2 block">Product Catalog</span>
        <h1 class="text-2xl sm:text-3xl md:text-5xl font-display font-black text-steel-50 mb-3">Piston Rings / 活塞环</h1>
        <p class="text-steel-400 text-sm sm:text-base max-w-2xl mx-auto">高品质活塞环系列 · 覆盖国内外主流车型 · 现货供应</p>
        <div class="flex flex-col items-center gap-0.5 mt-4">
          <span class="block w-10 h-px bg-crest-gold/50"></span>
          <span class="block w-6 h-px bg-crest-gold/20"></span>
        </div>
      </div>
    </section>

    <!-- Rings Grid -->
    <section id="rings-grid-section" class="px-4 sm:px-6 py-8 md:py-16 bg-steel-950/30">
      <div class="mx-auto max-w-7xl">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5 md:gap-8" id="rings-grid">
          <div class="col-span-full text-center py-20 text-steel-500 text-sm">正在加载活塞环产品...</div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-4 sm:px-6 py-12 md:py-16 text-center border-t border-steel-800/20">
      <div class="flex flex-col items-center gap-3">
        <div class="flex flex-col items-center leading-none">
          <span class="text-crest-gold text-sm tracking-[0.3em] font-medium uppercase">YH</span>
          <span class="text-steel-500 text-[10px] tracking-[0.5em] uppercase">Auto Parts</span>
        </div>
        <span class="block w-8 h-px bg-crest-gold/30"></span>
        <p class="text-steel-600 text-xs tracking-wider">广州 · 中国</p>
      </div>
    </footer>
  </main>

  <script is:inline>
    (async function() {
      try {
        const res = await fetch('https://www.yhautopartschina.com/api/products');
        if (!res.ok) {
          document.getElementById('rings-grid').innerHTML = '<div class="col-span-full text-center py-20 text-steel-500 text-sm">加载失败，请刷新重试</div>';
          return;
        }
        const allProducts = await res.json();
        const rings = allProducts.filter(p => p.category === 'Piston Ring');

        if (!rings.length) {
          document.getElementById('rings-grid').innerHTML = '<div class="col-span-full text-center py-20 text-steel-500 text-sm">暂无活塞环产品</div>';
          return;
        }

        const grid = document.getElementById('rings-grid');
        grid.innerHTML = rings.map((p) => {
          const details = p.details || {};
          const hasSpecs = details.specs && details.specs.length > 0;
          const hasSize = details.size && details.size.length > 0;
          const hasUsed = details.used && details.used.length > 0;

          function escHtml(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

          return `
          <article class="product-card group border border-steel-800/60 hover:border-crest-gold/30 bg-steel-950/50 transition-all duration-500" data-product-id="${escHtml(p.id)}">
            <div class="aspect-[4/3] overflow-hidden relative bg-steel-950">
              ${p.image ? `<img src="${escHtml(p.image)}" alt="${escHtml(p.title)}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />` : '<div class="w-full h-full flex items-center justify-center text-steel-700 text-xs">暂无图片</div>'}
              <div class="absolute top-0 left-0 bg-crest-gold text-crest-dark text-[10px] px-2 py-0.5 tracking-wider uppercase font-semibold">${escHtml(p.category)}</div>
            </div>
            <div class="p-4 sm:p-5">
              <h3 class="text-steel-100 text-sm sm:text-base font-semibold leading-snug mb-3 group-hover:text-crest-gold transition-colors">${escHtml(p.title)}</h3>

              ${hasSize ? `
              <div class="detail-section mb-3">
                <div class="flex items-center gap-2 mb-1.5">
                  <span class="text-[11px] text-crest-gold tracking-widest uppercase font-semibold">Size / Specs</span>
                  <span class="h-px flex-1 bg-crest-gold/20"></span>
                </div>
                <div class="text-steel-400 text-xs leading-relaxed">
                  ${details.size.map(l => '<div class="py-0.5">' + escHtml(l) + '</div>').join('')}
                </div>
              </div>` : ''}

              ${hasSpecs ? `
              <div class="detail-section mb-3">
                <div class="flex items-center gap-2 mb-1.5">
                  <span class="text-[11px] text-crest-gold tracking-widest uppercase font-semibold">环高×径向</span>
                  <span class="h-px flex-1 bg-crest-gold/20"></span>
                </div>
                <div class="text-steel-400 text-xs leading-relaxed">
                  ${details.specs.map(s => `<div class="py-0.5"><span class="text-crest-gold/70 font-medium">${escHtml(s.ring)}:</span> ${escHtml(s.hxr)}</div>`).join('')}
                </div>
              </div>` : ''}

              ${hasUsed ? `
              <div class="detail-section mb-3">
                <div class="flex items-center gap-2 mb-1.5">
                  <span class="text-[11px] text-crest-gold tracking-widest uppercase font-semibold">适用车型</span>
                  <span class="h-px flex-1 bg-crest-gold/20"></span>
                </div>
                <div class="text-steel-400 text-xs leading-relaxed">
                  ${details.used.slice(0, 3).map(l => '<div class="py-0.5">' + escHtml(l) + '</div>').join('')}
                  ${details.used.length > 3 ? '<div class="text-steel-600 text-[11px] mt-0.5">等 ' + (details.used.length - 1) + ' 个车型...</div>' : ''}
                </div>
              </div>` : ''}

              ${p.compatible ? `<p class="text-steel-500 text-[10px] leading-relaxed mt-2"><span class="text-steel-400 font-medium">适配:</span> ${escHtml(p.compatible.replace('适配: ',''))}</p>` : ''}
            </div>
          </article>`;
        }).join('');
      } catch(e) {
        document.getElementById('rings-grid').innerHTML = '<div class="col-span-full text-center py-20 text-steel-500 text-sm">加载失败: ' + e.message + '</div>';
      }
    })();
  </script>
</main>
</Layout>
