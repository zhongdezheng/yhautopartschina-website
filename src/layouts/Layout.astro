---
import { siteConfig } from '../data/products';

const { title = siteConfig.tagline, description = "High-quality piston & piston ring supplier for SEA, Middle East & Africa markets." } = Astro.props;
---

<!doctype html>
<html lang="zh" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark" />

    <title>{title} — {siteConfig.brandName}</title>

    <script type="importmap">
      {
        "imports": {
          "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js"
        }
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet" />

    <meta property="og:title" content={`${siteConfig.brandName} — ${title}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <style is:global>
      :root {
        --crest-gold: #C8A96E;
        --crest-silver: #B8BCC0;
        --crest-dark: #1A1C20;
        --crest-accent: #D4442A;
      }
      ::selection {
        background: var(--crest-gold);
        color: var(--crest-dark);
      }
      html { scroll-behavior: smooth; }
    </style>
  </head>
  <body class="bg-crest-dark text-steel-100 font-sans antialiased">
    <slot />
    <!-- i18n is handled inline in Header.astro — no duplicate module load needed -->
  </body>
</html>

<style is:global>
  /* Product card as link — preserve original card styling */
  a.product-card {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  a.product-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
</style>
